{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Huxley",
  "colors": {
    "primary": "#0f83c1",
    "light": "#35b8ff",
    "dark": "#0c2776"
  },
  "favicon": {
    "light": "/images/favicon-32.png",
    "dark": "/images/favicon-32.png"
  },
  "navigation": {
    "pages": [
      "huxley-documentation",
      {
        "group": "Design",
        "pages": [
          "database-schema",
          "environment-variables"
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/huxley-docs-logo.png",
    "dark": "/images/huxley-docs-logo.png",
    "href": "https://docs.huxley.dev"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "github",
      "label": "Github",
      "href": "https://github.com/huxley-dev/huxleygithub.com/huxley-dev/huxley"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/huxley_dev"
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "description": "Open-Source Automation Platform",
  "appearance": {
    "strict": true,
    "default": "dark"
  },
  "background": {
    "color": {
      "dark": "#0a0b0d"
    }
  },
  "fonts": {
    "family": "Spectral"
  }
}
